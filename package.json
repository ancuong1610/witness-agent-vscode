      },
      {
        "command": "witness.status",
        "title": "Status",
        "category": "Witness"
      },
      {
        "command": "witness.saveProgress",
        "title": "Save Progress",
        "category": "Witness"
      },
      {
        "command": "witness.resume",
        "title": "Resume",
        "category": "Witness"
      },
      {
        "command": "witness.switchTask",
        "title": "Switch Task",
        "category": "Witness"
      },
      {
        "command": "witness.fixIssue",
        "title": "Fix Issue",
        "category": "Witness"
      },
      {
        "command": "witness.updateMemory",
        "title": "Update Memory",
        "category": "Witness"
      },
      {
        "command": "witness.checkMemoryUpdate",
        "title": "Check Memory Update",
        "category": "Witness"
      },
      {
        "command": "witness.cheatsheet",
        "title": "Cheatsheet",
        "category": "Witness"
      },
      {
        "command": "witness.startNewTask",
        "title": "Start New Task",
        "category": "Witness"
      },
      {
        "command": "witness.enableProject",
        "title": "Enable for This Project",
        "category": "Witness"
      },
      {
        "command": "witness.startTrackingTask",
        "title": "Start Tracking This Task",
        "category": "Witness"
      },
      {
        "command": "witness.createCheckpoint",
        "title": "Create Checkpoint",
        "category": "Witness"
      },
      {
        "command": "witness.resumeWithWitness",
        "title": "Resume with Witness",
