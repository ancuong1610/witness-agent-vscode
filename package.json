        "category": "Witness"
      },
      {
        "command": "witness.generateHandover",
        "title": "Generate Handover",
        "category": "Witness"
      },
      {
        "command": "witness.validateHandover",
        "title": "Validate Handover",
        "category": "Witness"
      },
      {
        "command": "witness.createResumeProbe",
        "title": "Create Resume Probe",
        "category": "Witness"
      },
      {
        "command": "witness.compressState",
        "title": "Compress Current State",
        "category": "Witness"
      },
      {
        "command": "witness.startSubagentTask",
        "title": "Start Subagent Task",
        "category": "Witness"
