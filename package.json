    "commands": [
      {
        "command": "witness.initProject",
        "title": "Initialize Project",
        "category": "Witness"
      },
      {
        "command": "witness.startSession",
        "title": "Start Session",
        "category": "Witness"
      },
      {
        "command": "witness.recordContext",
        "title": "Record Context Snapshot",
        "category": "Witness"
      },
      {
