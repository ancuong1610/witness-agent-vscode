{
  "name": "witness-agent",
  "displayName": "Witness Agent",
  "description": "A VS Code extension that creates a repo-local .witness/ continuity system for AI-assisted coding workflows.",
  "version": "0.2.0",
  "publisher": "witness-agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ancuong1610/witness-agent-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "keywords": [
    "copilot",
    "context",
    "handover",
    "ai-coding",
    "witness"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:.witness/index.md",
    "onCommand:witness.initProject",
    "onCommand:witness.startSession",
    "onCommand:witness.recordContext",
    "onCommand:witness.observeWorkspace",
    "onCommand:witness.createADR",
    "onCommand:witness.recordSubagent",
    "onCommand:witness.assessRisk",
    "onCommand:witness.generateHandover",
    "onCommand:witness.validateHandover",
    "onCommand:witness.createResumeProbe",
    "onCommand:witness.compressState",
    "onCommand:witness.startSubagentTask",
    "onCommand:witness.createSubagentContextPacket",
    "onCommand:witness.recordSubagentEvidence",
    "onCommand:witness.completeSubagentTask",
    "onCommand:witness.reviewSubagentTask",
    "onCommand:witness.createContextPacket",
    "onCommand:witness.showWorkspaceStatus",
    "onCommand:witness.checkpointNow",
    "onCommand:witness.prepareSessionSwitch",
    "onCommand:witness.resumeSession",
    "onCommand:witness.generateEvaluationSummary",
    "onCommand:witness.resolveContinuityIssue",
    "onCommand:witness.startWithWitness",
    "onCommand:witness.start",
    "onCommand:witness.status",
    "onCommand:witness.saveProgress",
    "onCommand:witness.resume",
    "onCommand:witness.switchTask",
    "onCommand:witness.fixIssue",
    "onCommand:witness.updateMemory",
    "onCommand:witness.checkMemoryUpdate",
    "onCommand:witness.cheatsheet",
    "onCommand:witness.startNewTask",
    "onCommand:witness.enableProject",
    "onCommand:witness.startTrackingTask",
    "onCommand:witness.createCheckpoint",
    "onCommand:witness.resumeWithWitness",
    "onCommand:witness.updateProjectMemoryWithAgent",
    "onCommand:witness.validateArtifactMaintenance"
  ],
