      },
      {
        "command": "witness.reviewSubagentTask",
        "title": "Review Subagent Task",
        "category": "Witness"
      },
      {
        "command": "witness.createContextPacket",
        "title": "Create Context Packet",
        "category": "Witness"
      },
      {
        "command": "witness.showWorkspaceStatus",
        "title": "Show Workspace Status",
        "category": "Witness"
      },
      {
        "command": "witness.checkpointNow",
        "title": "Checkpoint Now",
        "category": "Witness"
      },
      {
        "command": "witness.prepareSessionSwitch",
        "title": "Prepare Session Switch",
        "category": "Witness"
      },
      {
        "command": "witness.resumeSession",
        "title": "Resume Session",
        "category": "Witness"
      },
      {
        "command": "witness.generateEvaluationSummary",
        "title": "Generate Evaluation Summary",
        "category": "Witness"
      },
      {
        "command": "witness.resolveContinuityIssue",
        "title": "Resolve Continuity Issue",
